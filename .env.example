# ===========================================
# Vee Commerce Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.

# ---- Database ----
DATABASE_URL=postgresql://vee:vee_dev_password@localhost:5432/vee

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth (NextAuth.js) ----
NEXTAUTH_SECRET=your-super-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3000
ADMIN_NEXTAUTH_URL=http://localhost:3001

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- S3 / Cloudflare R2 ----
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_BUCKET=vee-assets
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ---- Meilisearch ----
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=vee_meili_dev_key

# ---- Email (Resend) ----
RESEND_API_KEY=re_...
EMAIL_FROM=hallo@vee-handmade.de

# ---- Etsy Integration ----
ETSY_API_KEY=
ETSY_SHARED_SECRET=
ETSY_SHOP_ID=

# ---- Amazon Integration ----
AMAZON_SELLER_ID=
AMAZON_MWS_ACCESS_KEY=
AMAZON_MWS_SECRET_KEY=
AMAZON_MARKETPLACE_ID=

# ---- Analytics ----
PLAUSIBLE_DOMAIN=vee-handmade.de

# ---- Public URLs ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
